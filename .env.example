# ─────────────────────────────────────────────────────────────
# GA4 "trending posts" integration (optional)
# ─────────────────────────────────────────────────────────────
# When set, the build fetches the most-trafficked /posts/ pages from the
# last 30 days and marks them "trending". Without these, the site falls
# back to the manual `trending: true` flag in each post's frontmatter.
#
# Set these in Vercel → Project → Settings → Environment Variables.

# Numeric GA4 property id (Admin → Property Settings → Property ID)
# cubagarcia.com property = 523095423 (account 383243897)
GA4_PROPERTY_ID=523095423

# Full service-account JSON on ONE line (paste the whole key file contents).
# The service account's email must be added as a Viewer on the GA4 property
# (Admin → Property Access Management).
GA_SERVICE_ACCOUNT_JSON=

# --- Local dev alternative to GA_SERVICE_ACCOUNT_JSON ---
# Instead of the inline JSON above, point to a key file on disk:
# GOOGLE_APPLICATION_CREDENTIALS=./ga-service-account.json
