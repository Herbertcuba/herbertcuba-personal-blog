{# ═══════════════════ HERO ═══════════════════ #}
<header class="apex-hero">
  <div class="apex-kicker mono"><span class="slash">//</span>the operating model</div>
  <h1 class="apex-title">APEX<span class="cursor">_</span></h1>
  <div class="apex-expand mono">Agentic Production Execution</div>
  <p class="apex-lede">A production-grade operating model for teams where <strong>humans design and verify</strong> while <strong>agents execute and iterate</strong>. Organizational scaffolding that makes agentic execution reliable, measurable, and improvable at scale.</p>
  <div class="apex-statstrip">
    <div class="apex-stat"><div class="apex-stat__num">3</div><div class="apex-stat__lbl mono">phases</div></div>
