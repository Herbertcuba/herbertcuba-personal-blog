---
layout: base.njk
isArticle: true
---

<article class="post">
  <div class="container">
    <header class="post-header">
      <div class="meta">
        <time datetime="{{ date }}">{{ date | isoDate }}</time>
        <span>// TRANSMISSION</span>
      </div>
      <h1>{{ title }}</h1>
      {% if excerpt %}
        <p class="lead">{{ excerpt }}</p>
      {% endif %}
    </header>
  </div>

  {% if epaper %}
  <div class="container container--narrow" style="margin-bottom:1rem;">
    <button
      class="epaper-download-btn js-open-book-modal"
      data-book="{{ epaper.title }}"
      data-download="{{ epaper.download }}"
      type="button">
      <svg width="16" height="16" viewBox="0 0 16 16" fill="none" style="vertical-align:-2px;margin-right:6px;">
        <path d="M8 1v9m0 0L5 7m3 3 3-3M2 11v2a1 1 0 001 1h10a1 1 0 001-1v-2" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
      Download this as an e-paper
    </button>
  </div>
  {% endif %}

  <div class="container container--full">
    {% if featuredImage %}
      <img src="{{ featuredImage }}" alt="" class="post-hero-image" />
    {% endif %}
  </div>

  <div class="prose" id="article-content">
    {{ content | safe }}
  </div>

  <!-- Lightbox for article images -->
  <div id="lightbox" class="lightbox" onclick="this.classList.remove('active')">
    <img id="lightbox-img" src="" alt="" />
  </div>
  <script>
    document.getElementById('article-content').addEventListener('click', function(e) {
      if (e.target.tagName === 'IMG' && !e.target.classList.contains('post-hero-image')) {
        document.getElementById('lightbox-img').src = e.target.src;
        document.getElementById('lightbox').classList.add('active');
      }
    });
  </script>

  {% if tags %}
  <div class="container container--narrow">
    <div class="post-tags">
      {% for tag in tags %}
        <span class="post-tag">{{ tag }}</span>
      {% endfor %}
    </div>
  </div>
  {% endif %}
</article>
