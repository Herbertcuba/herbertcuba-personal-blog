{# ═══════════════════════════════════════════════════════════════════════════
   Global nav — matrix-professional redesign
   Active link: pass `activeNav` ("books"|"about") from the page to turn it green.
   Insights/APEX anchor to home sections; on home they're same-page.
   ═══════════════════════════════════════════════════════════════════════════ #}
<nav class="site-nav">
  <a class="site-nav__brand" href="/" aria-label="{{ site.title }} home">
    <span class="slash">//</span>
    <span class="site-nav__name">HERBERT CUBA GARCIA</span>
  </a>
  <button class="site-nav__toggle mono" id="navToggle" aria-label="Menu" aria-expanded="false">≡</button>
  <div class="site-nav__links" id="navLinks">
    <a href="/#themes">Insights</a>
    <a href="/apex/"{% if activeNav == "apex" %} class="is-active"{% endif %}>APEX</a>
    <a href="/books/"{% if activeNav == "books" %} class="is-active"{% endif %}>Books</a>
    <a href="/about/"{% if activeNav == "about" %} class="is-active"{% endif %}>About</a>
    <a class="site-nav__cta" href="/about/#contact">Contact ↗</a>
  </div>
</nav>
